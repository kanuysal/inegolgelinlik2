# =============================================================================
# RE:GALIA — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your Supabase credentials
# Get these from: https://supabase.com → Project Settings → API
# =============================================================================

# Supabase Project URL (safe to expose — public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Key (safe to expose — public, restricted by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (NEVER expose — server-side only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (for OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend API Key (for email notifications)
RESEND_API_KEY=your-resend-api-key-here

# Resend From Email (REQUIRED for email delivery to work)
# Must be a verified sender on your Resend account
# e.g., "RE:GALIA <no-reply@yourdomain.com>"
# Without this, emails only reach the Resend account owner (test mode)
RESEND_FROM_EMAIL="RE:GALIA <no-reply@yourdomain.com>"

# Site URL (for email links)
NEXT_PUBLIC_SITE_URL=https://regalia-scroll.vercel.app

# Kustomer CRM API Key (for forwarding messages to support agents)
# Get this from: Kustomer → Settings → API Keys
KUSTOMER_API_KEY=your-kustomer-api-key-here

# Kustomer Webhook Secret (for verifying inbound webhooks from Kustomer)
# Set this to match the secret configured in Kustomer → Settings → Webhooks
KUSTOMER_WEBHOOK_SECRET=your-webhook-secret-here
