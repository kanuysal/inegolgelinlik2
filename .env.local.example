# =============================================================================
# RE:GALIA — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your Supabase credentials
# Get these from: https://supabase.com → Project Settings → API
# =============================================================================

# Supabase Project URL (safe to expose — public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Key (safe to expose — public, restricted by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (NEVER expose — server-side only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (for OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
